{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vite/client"]
  },
  "include": ["src", "tools", "tests", "vite.config.ts", "vitest.config.ts", "playwright.config.ts"],
  // The fixture repo is DATA, not source: it is a miniature repository the
  // extractor is run against, with its own tsconfig and its own `paths` aliases.
  // Type-checking it against the Visual Specs config would be checking the input.
  "exclude": ["node_modules", "dist", "tools/extractor/fixtures"]
}
